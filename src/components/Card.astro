---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ...props } = data;
---

<li class="my-2 group">
  <a
    href={getPath(id, filePath)}
    class="flex flex-col sm:flex-row gap-4 p-4 rounded-2xl bg-white dark:bg-slate-900 border border-border shadow-sm hover:shadow-xl hover:shadow-accent/5 transition-all duration-300"
  >
    {
      data.ogImage && (
        <div class="flex-none w-full sm:w-48 h-48 sm:h-32 overflow-hidden rounded-2xl border border-border">
          <img 
            src={typeof data.ogImage === 'string' ? data.ogImage : data.ogImage.src} 
            alt={title}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
          />
        </div>
      )
    }
    <div class="flex flex-col justify-center flex-1">
      {
        data.category && (
          <span class="mb-2 block text-xs font-bold uppercase tracking-wider text-accent/80">
            {data.category}
          </span>
        )
      }
      <Heading
        class="text-xl font-bold text-foreground group-hover:text-accent transition-colors"
        style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
      >
        {title}
      </Heading>
      <div class="mt-2 opacity-80">
        <Datetime {...props} />
      </div>
      <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 line-clamp-2">{description}</p>
    </div>
  </a>
</li>
